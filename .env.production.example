# Production env template — copy to .env.production (gitignored). Never commit secrets.

NODE_ENV=production
POSTGRES_USER=watchify
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=watchify

NEXT_PUBLIC_APP_URL=https://watchify.example.com
NEXTAUTH_URL=https://watchify.example.com
NEXTAUTH_SECRET=
REALTIME_SECRET=
TOKEN_ENCRYPTION_SECRET=
NEXT_PUBLIC_REALTIME_URL=https://rt.watchify.example.com
ALLOWED_ORIGINS=https://watchify.example.com
DATABASE_URL=postgresql://watchify:change-me-strong@db:5432/watchify?schema=public

WATCHIFY_DEV_BILLING=false
NEXT_PUBLIC_SHOW_DEMO_LOGIN=false
WATCHIFY_SEED_DEMO_USERS=false
WATCHIFY_OPEN_RELAY_TURN=false
WATCHIFY_EMAIL_ETHEREAL=false

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PARTY=
STRIPE_TAX_ENABLED=false

# Email
RESEND_API_KEY=
EMAIL_FROM=Watchify <hello@watchify.example.com>

# Catalog + presence
TMDB_API_KEY=
# Free Trakt OAuth app — redirect must match the Trakt dashboard exactly.
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_REDIRECT_URI=https://watchify-web-9rx1.onrender.com/api/trakt/callback

# WebRTC
TURN_URL=
TURN_USER=
TURN_PASS=

# Optional — Amazon Associates tag for Rent/Buy / Prime Video deep links (free signup).
# Leave empty until you have a real tag from https://affiliate-program.amazon.com/
# AMAZON_AFFILIATE_TAG=
# NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=

# Optional
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
