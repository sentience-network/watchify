# App
NEXT_PUBLIC_APP_URL=http://localhost:3344

# Realtime (Socket.io companion â€” Week 2)
# npm run dev starts Next :3344 + realtime :3345 together
REALTIME_PORT=3345
NEXT_PUBLIC_REALTIME_URL=http://localhost:3345
# Optional dedicated secret (falls back to NEXTAUTH_SECRET)
REALTIME_SECRET=
# Comma-separated production web origins accepted by realtime/Next deployments
ALLOWED_ORIGINS=http://localhost:3344
# Optional production TURN relay for WebRTC face video. STUN-only is unreliable
# on strict NATs; use short-lived TURN credentials where your provider supports it.
TURN_URL=
TURN_USER=
TURN_PASS=

# Database (SQLite local â€” Week 1)
# File is created under prisma/ when you migrate.
DATABASE_URL="file:./dev.db"
# Production Postgres example (swap provider in prisma/schema.prisma too):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/watchify?sslmode=require"

# NextAuth (required for production sign-in sessions)
# Generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3344
NEXTAUTH_SECRET=

# Optional OAuth (leave blank to hide provider buttons)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# â”€â”€â”€ TMDB (optional live watch/providers â€” metadata only, never streams) â”€â”€â”€
# Free key: https://www.themoviedb.org/settings/api
# Without a key, Watchify uses the curated demo catalog + deep-link patterns.
TMDB_API_KEY=

# â”€â”€â”€ Trakt (Week 4 â€” optional, honest history import) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Create an OAuth app at https://trakt.tv/oauth/applications
# Callback must exactly match TRAKT_REDIRECT_URI.
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_REDIRECT_URI=http://localhost:3344/api/trakt/callback
# Required for Trakt. 32+ random characters; rotate only with a token migration.
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_SECRET=

# Optional PostHog browser delivery. Internal aggregate events work without it.
# Third-party loading must remain gated by analytics consent.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# â”€â”€â”€ Stripe (Week 3 â€” live path) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Leave blank â†’ Pricing runs in honest demo mode (plan still persists in DB).
#
# Dashboard setup (test mode first):
# 1. Products â†’ Create product "Watchify Plus" ($4.99/mo recurring) â†’ copy Price ID â†’ STRIPE_PRICE_PLUS
# 2. Create product "Watchify Party" ($9.99/mo recurring) â†’ copy Price ID â†’ STRIPE_PRICE_PARTY
# 3. Developers â†’ API keys â†’ Secret key + Publishable key
# 4. Developers â†’ Webhooks â†’ Add endpoint:
#      URL: https://YOUR_HOST/api/stripe/webhook   (local: stripe listen --forward-to localhost:3344/api/stripe/webhook)
#      Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
#      Copy signing secret â†’ STRIPE_WEBHOOK_SECRET
# 5. Settings â†’ Customer portal â†’ enable cancel / plan changes
# 6. (Optional) Settings â†’ Tax â†’ Enable Stripe Tax, then set STRIPE_TAX_ENABLED=true
#
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PARTY=
# Set to "true" only after Tax is enabled in the Stripe Dashboard
STRIPE_TAX_ENABLED=false

# â”€â”€â”€ Email (verify + password reset) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Priority: RESEND_API_KEY â†’ SMTP_* â†’ console fallback (prints link in server logs)
RESEND_API_KEY=
EMAIL_FROM=Watchify <onboarding@resend.dev>
# Optional SMTP (Nodemailer) if not using Resend:
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Notes:
# - Users, friends, parties, messages, presence, watchlists, and plan live in the DB.
# - Party chat/playback fan-out via Socket.io on REALTIME_PORT; Prisma persists.
# - Stripe webhooks + /api/stripe/session update User.plan; JWT refreshes from DB.
# - Demo checkout without Stripe keys: PATCH /api/me { plan } (signed-in).
# - Webhook endpoint: POST /api/stripe/webhook
# - Health: GET /api/health  (+ realtime root on :3345)
# - Moderation: /admin/reports (alex=admin, jordan=mod after seed)
# - Demo login after seed: alex@watchify.app / watchify-demo (pre-verified)
# - Second browser: jordan@watchify.app / watchify-demo
# - SQLite backup: copy prisma/dev.db (stop writes first) or switch to Postgres for prod

# ─── Soft-launch / local feature switches ──────────────────────────────────
# Local plan grants without Stripe (never enable in production).
WATCHIFY_DEV_BILLING=true
# Show seeded alex@ login hint on /auth/signin
NEXT_PUBLIC_SHOW_DEMO_LOGIN=true
# Seed fictional friends/parties (set false for empty production-like DB)
WATCHIFY_SEED_DEMO_USERS=true
# Prefer Ethereal test SMTP when Resend/SMTP unset (set false for console-only)
WATCHIFY_EMAIL_ETHEREAL=true
# Use Open Relay TURN when TURN_* / Metered unset (dev NAT). Prefer your own TURN in prod.
WATCHIFY_OPEN_RELAY_TURN=true
# Optional dedicated TURN (overrides Open Relay when all three are set)
TURN_URL=
TURN_USER=
TURN_PASS=
# Metered TURN credential API (preferred): https://www.metered.ca/docs/turn-rest-api/get-credential/
METERED_DOMAIN=
METERED_TURN_API_KEY=
